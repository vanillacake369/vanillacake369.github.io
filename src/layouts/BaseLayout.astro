---
import '../styles/global.css';
import '../styles/themes/dark.css';
import '../styles/vim-ui.css';
import ThemeInitScript from '../components/ThemeInitScript.astro';
import LangInitScript from '../components/LangInitScript.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import LangToggle from '../components/LangToggle.astro';
import SEO from '../components/SEO.astro';
import { translations } from '../i18n/translations';
import VimSearch from '../components/VimSearch.astro';
import FuzzyFinder from '../components/FuzzyFinder.astro';
import WhichKey from '../components/WhichKey.astro';
import Analytics from '../components/Analytics.astro';
import { SITE_CONFIG } from '../config';

interface Props {
  title?: string;
  description?: string;
  lang?: 'ko' | 'en';
  seoType?: 'article' | 'website';
  publishedDate?: Date;
  tags?: string[];
}

const {
  title = SITE_CONFIG.title,
  description = SITE_CONFIG.description,
  lang = 'ko',
  seoType = 'website',
  publishedDate,
  tags,
} = Astro.props;

const siteTitle = SITE_CONFIG.title;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="noai, noimageai" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <link rel="alternate" hreflang="ko" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" crossorigin="anonymous" />
    <title>{title === siteTitle ? title : `${title} — ${siteTitle}`}</title>
    <SEO
      title={title}
      description={description}
      url={canonicalUrl}
      type={seoType}
      publishedDate={publishedDate}
      tags={tags}
    />
    <ThemeInitScript />
    <LangInitScript />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-wrapper header-inner">
        <a href="/" class="site-title">{siteTitle}</a>
        <nav class="site-nav" aria-label="Main navigation">
          <a href="/"
            data-i18n="nav.home"
            data-i18n-ko={translations.ko['nav.home']}
            data-i18n-en={translations.en['nav.home']}
          >{translations.ko['nav.home']}</a>
          <a href="/about"
            data-i18n="nav.about"
            data-i18n-ko={translations.ko['nav.about']}
            data-i18n-en={translations.en['nav.about']}
          >{translations.ko['nav.about']}</a>
          <a href="/tags"
            data-i18n="nav.tags"
            data-i18n-ko={translations.ko['nav.tags']}
            data-i18n-en={translations.en['nav.tags']}
          >{translations.ko['nav.tags']}</a>
          <a href="/calendar"
            data-i18n="nav.calendar"
            data-i18n-ko={translations.ko['nav.calendar']}
            data-i18n-en={translations.en['nav.calendar']}
          >{translations.ko['nav.calendar']}</a>
          <button id="nav-search-btn" class="nav-icon-btn" aria-label="Search" type="button" title="/ or Ctrl+P">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
          <ThemeToggle />
          <LangToggle />
          <button id="mobile-search-btn" class="mobile-search-btn" aria-label="Open search" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="site-wrapper">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-wrapper footer-inner">
        <span
          data-i18n="footer.rights"
          data-i18n-ko={`© ${new Date().getFullYear()} ${SITE_CONFIG.author}. ${translations.ko['footer.rights']}`}
          data-i18n-en={`© ${new Date().getFullYear()} ${SITE_CONFIG.author}. ${translations.en['footer.rights']}`}
        >
          &copy; {new Date().getFullYear()} {SITE_CONFIG.author}. {translations.ko['footer.rights']}
        </span>
        <div class="footer-links">
          <a href={SITE_CONFIG.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">GitHub</a>
          <a href={`mailto:${SITE_CONFIG.email}`} aria-label="Email">Email</a>
          <a href={SITE_CONFIG.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">LinkedIn</a>
          <a href="/rss.xml" class="rss-link" aria-label="RSS Feed">RSS</a>
        </div>
      </div>
    </footer>

    <VimSearch />
    <FuzzyFinder />
    <WhichKey />
    <Analytics />
  </body>
</html>

<script>
  import { init as initKeyboard } from '../vim/keyboard-controller';
  import * as vimSearch from '../vim/vim-search';

  function initLayout(): void {
    // Start the single global keyboard listener
    initKeyboard();

    // Search buttons open VimSearch (fallback to direct DOM if module not yet initialized)
    const searchBtns = document.querySelectorAll('#mobile-search-btn, #nav-search-btn');
    searchBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Try the module API first
        try {
          vimSearch.open(() => {});
        } catch {
          // Fallback: directly show the search bar and focus input
          const bar = document.getElementById('vim-search-bar');
          const input = bar?.querySelector<HTMLInputElement>('.vim-search-input');
          if (bar && input) {
            bar.hidden = false;
            input.value = '';
            input.focus();
          }
        }
      });
    });

  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLayout);
  } else {
    initLayout();
  }
</script>

<style>
  /* Header */
  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding: var(--spacing-md) 0;
    background-color: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
  }

  .site-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .site-title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    gap: var(--spacing-lg);
    align-items: center;
  }

  .site-nav a {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .site-nav a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  /* Main */
  .site-main {
    flex: 1;
    padding: var(--spacing-2xl) 0;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--spacing-lg) 0;
    margin-top: auto;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .footer-links {
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
  }

  .footer-links a {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .rss-link {
    border: 1px solid var(--color-border);
    padding: 0.15em 0.5em;
    border-radius: 3px;
  }

  .rss-link:hover {
    border-color: var(--color-accent);
  }

  .nav-icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    transition: color 0.15s ease;
  }

  .nav-icon-btn:hover {
    color: var(--color-text);
  }

  /* Mobile search button — hidden on desktop, shown via vim-ui.css media query */
  .mobile-search-btn {
    display: none;
  }

  /* Responsive */
  @media (max-width: 480px) {
    .site-nav {
      gap: var(--spacing-md);
    }

    .site-nav a {
      font-size: 0.85rem;
    }
  }
</style>
