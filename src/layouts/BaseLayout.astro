---
import '../styles/global.css';
import '../styles/themes/dark.css';
import '../styles/vim-ui.css';
import ThemeInitScript from '../components/ThemeInitScript.astro';
import LangInitScript from '../components/LangInitScript.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import LangToggle from '../components/LangToggle.astro';
import SEO from '../components/SEO.astro';
import { translations } from '../i18n/translations';
import VimSearch from '../components/VimSearch.astro';
import FuzzyFinder from '../components/FuzzyFinder.astro';
import WhichKey from '../components/WhichKey.astro';
import Analytics from '../components/Analytics.astro';
import { SITE_CONFIG } from '../config';

interface Props {
  title?: string;
  description?: string;
  lang?: 'ko' | 'en';
  seoType?: 'article' | 'website';
  publishedDate?: Date;
  tags?: string[];
}

const {
  title = SITE_CONFIG.title,
  description = SITE_CONFIG.description,
  lang = 'ko',
  seoType = 'website',
  publishedDate,
  tags,
} = Astro.props;

const siteTitle = SITE_CONFIG.title;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <ThemeInitScript />
    <LangInitScript />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="noai, noimageai" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="any" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" media="print" onload="this.media='all'" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" crossorigin="anonymous" />
    <title>{title === siteTitle ? title : `${title} — ${siteTitle}`}</title>
    <SEO
      title={title}
      description={description}
      url={canonicalUrl}
      type={seoType}
      publishedDate={publishedDate}
      tags={tags}
    />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-wrapper header-inner">
        <a href="/" class="site-title">{siteTitle}</a>
        <nav class="site-nav" aria-label="Main navigation">
          <a href="/about"
            data-i18n="nav.about"
            data-i18n-ko={translations.ko['nav.about']}
            data-i18n-en={translations.en['nav.about']}
          >{translations.ko['nav.about']}</a>
          <a href="/series"
            data-i18n="nav.series"
            data-i18n-ko={translations.ko['nav.series']}
            data-i18n-en={translations.en['nav.series']}
          >{translations.ko['nav.series']}</a>
          <a href="/tags"
            data-i18n="nav.tags"
            data-i18n-ko={translations.ko['nav.tags']}
            data-i18n-en={translations.en['nav.tags']}
          >{translations.ko['nav.tags']}</a>
          <a href="/calendar"
            data-i18n="nav.calendar"
            data-i18n-ko={translations.ko['nav.calendar']}
            data-i18n-en={translations.en['nav.calendar']}
          >{translations.ko['nav.calendar']}</a>
          <button id="nav-search-btn" class="nav-icon-btn" aria-label="Search" type="button" title="/ or Ctrl+P">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
          <ThemeToggle />
          <LangToggle />
          <button id="mobile-search-btn" class="mobile-search-btn" aria-label="Open search" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="site-wrapper">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-wrapper footer-inner">
        <div class="footer-links">
          <a href={SITE_CONFIG.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">GitHub</a>
          <a href={`mailto:${SITE_CONFIG.email}`} aria-label="Email">Email</a>
          <a href={SITE_CONFIG.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">LinkedIn</a>
          <a href="/rss.xml" class="rss-link" aria-label="RSS Feed">RSS</a>
        </div>
      </div>
    </footer>

    <VimSearch />
    <FuzzyFinder />
    <WhichKey />
    <Analytics />
  </body>
</html>

<script>
  import { init as initKeyboard } from '../vim/keyboard-controller';
  import * as vimSearch from '../vim/vim-search';
  import * as fuzzyFinder from '../vim/fuzzy-finder';
  import * as whichKey from '../vim/which-key';

  function initLayout(): void {
    // Initialize vim components (ensure DOM refs are bound before keyboard controller)
    const searchBar = document.getElementById('vim-search-bar');
    const searchInput = searchBar?.querySelector<HTMLInputElement>('.vim-search-input');
    const searchCount = searchBar?.querySelector<HTMLElement>('.vim-search-count');
    if (searchBar && searchInput && searchCount) {
      vimSearch.init({ bar: searchBar, input: searchInput, count: searchCount });
    }

    const fuzzyOverlay = document.getElementById('vim-fuzzy-overlay');
    const fuzzyInput = fuzzyOverlay?.querySelector<HTMLInputElement>('.vim-fuzzy-input');
    const fuzzyResults = fuzzyOverlay?.querySelector<HTMLElement>('.vim-fuzzy-results');
    const fuzzyPreview = fuzzyOverlay?.querySelector<HTMLElement>('.vim-fuzzy-preview');
    const fuzzyStatus = fuzzyOverlay?.querySelector<HTMLElement>('.vim-fuzzy-status');
    if (fuzzyOverlay && fuzzyInput && fuzzyResults && fuzzyPreview && fuzzyStatus) {
      fuzzyFinder.init({ overlay: fuzzyOverlay, input: fuzzyInput, resultList: fuzzyResults, preview: fuzzyPreview, status: fuzzyStatus });
    }

    const whichKeyEl = document.getElementById('vim-whichkey');
    const whichKeyInner = whichKeyEl?.querySelector<HTMLElement>('.vim-whichkey-inner');
    if (whichKeyEl && whichKeyInner) {
      whichKey.init({ el: whichKeyEl, inner: whichKeyInner });
    }

    // Start the single global keyboard listener (AFTER components are initialized)
    initKeyboard();

    // Search buttons open fuzzy finder
    const searchBtns = document.querySelectorAll('#mobile-search-btn, #nav-search-btn');
    searchBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        fuzzyFinder.open('files', () => {});
      });
    });

  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLayout);
  } else {
    initLayout();
  }
</script>

<style>
  /* Header */
  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding: 0.85rem 0;
    background-color: color-mix(in srgb, var(--color-bg) 88%, var(--color-surface) 12%);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    min-height: 2.5rem;
  }

  .site-title {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.98rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    white-space: nowrap;
  }

  .site-title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .site-nav a {
    font-size: 0.82rem;
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .site-nav a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  /* Main */
  .site-main {
    flex: 1;
    padding: 2.4rem 0 3rem;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 1rem 0;
    margin-top: auto;
    background-color: color-mix(in srgb, var(--color-bg) 78%, var(--color-surface) 22%);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .footer-links {
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
  }

  .footer-links a {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .rss-link {
    border: 1px solid var(--color-border);
    padding: 0.15em 0.5em;
    border-radius: 2px;
    background-color: var(--color-surface);
  }

  .rss-link:hover {
    border-color: var(--color-accent);
  }

  .nav-icon-btn {
    background: none;
    border: 1px solid transparent;
    cursor: pointer;
    padding: 0.25rem;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    transition: color 0.15s ease;
    border-radius: 2px;
  }

  .nav-icon-btn:hover {
    color: var(--color-text);
    border-color: var(--color-border);
    background-color: var(--color-surface);
  }

  /* Mobile search button — hidden on desktop, shown via vim-ui.css media query */
  .mobile-search-btn {
    display: none;
  }

  /* Responsive */
  @media (max-width: 480px) {
    .header-inner {
      align-items: flex-start;
    }

    .site-title {
      padding-top: 0.35rem;
    }

    .site-nav {
      justify-content: flex-end;
      gap: 0.6rem;
    }

    .site-nav a {
      font-size: 0.74rem;
    }
  }
</style>
