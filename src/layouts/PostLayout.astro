---
import BaseLayout from './BaseLayout.astro';
import MermaidInit from '../components/MermaidInit.astro';
import CodeCopyButton from '../components/CodeCopyButton.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
  category?: string;
  lang?: 'ko' | 'en';
  heroImage?: string;
}

const {
  title,
  description,
  date,
  updatedDate,
  tags = [],
  category = 'uncategorized',
  lang = 'ko',
  heroImage,
} = Astro.props;

function formatDate(d: Date, locale: string): string {
  return d.toLocaleDateString(locale, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const locale = lang === 'ko' ? 'ko-KR' : 'en-US';
const formattedDate = formatDate(date, locale);
const formattedUpdatedDate = updatedDate ? formatDate(updatedDate, locale) : null;
---

<BaseLayout title={title} description={description} lang={lang}>
  <div class="post-with-toc">
    <div class="toc-trigger">
      <aside class="toc-sidebar">
        <slot name="toc" />
      </aside>
    </div>

    <article class="post">
      {heroImage && (
        <figure class="post-hero">
          <img src={heroImage} alt={title} />
        </figure>
      )}

      <header class="post-header">
        <div class="post-meta-top">
          <span class="post-category">{category}</span>
        </div>

        <h1 class="post-title">{title}</h1>

        <div class="post-meta">
          <time class="post-date" datetime={date.toISOString()}>
            {formattedDate}
          </time>
          {formattedUpdatedDate && (
            <span class="post-updated">
              (Updated: <time datetime={updatedDate!.toISOString()}>{formattedUpdatedDate}</time>)
            </span>
          )}
        </div>

        {tags.length > 0 && (
          <div class="post-tags" aria-label="Tags">
            {tags.map((tag) => (
              <a href={`/tags/${tag}`} class="post-tag">#{tag}</a>
            ))}
          </div>
        )}
      </header>

      <div class="post-body prose">
        <slot />
      </div>

      <MermaidInit />
      <CodeCopyButton />
    </article>
  </div>
</BaseLayout>

<style>
  /* Layout: post + sliding TOC */
  .post-with-toc {
    position: relative;
  }

  /* Hover trigger — invisible zone on right side, always receives pointer */
  .toc-trigger {
    position: fixed;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    width: 220px;
    max-height: 60vh;
    z-index: 100;
    padding: 0.75rem;
  }

  /* TOC panel — hidden by default, shown on scroll or hover */
  .toc-sidebar {
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    overflow-y: auto;
    max-height: 55vh;
    scrollbar-width: none;
  }

  .toc-sidebar::-webkit-scrollbar {
    display: none;
  }

  /* Show on hover over trigger zone */
  .toc-trigger:hover .toc-sidebar {
    opacity: 1;
    pointer-events: auto;
  }

  /* Post */
  .post {
    max-width: 100%;
  }

  .post-hero {
    margin-bottom: var(--spacing-2xl);
    border-radius: 6px;
    overflow: hidden;
  }

  .post-hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-header {
    margin-bottom: var(--spacing-2xl);
    padding-bottom: var(--spacing-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta-top {
    margin-bottom: var(--spacing-sm);
  }

  .post-category {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    font-weight: 600;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-md);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
  }

  .post-date {
    font-style: normal;
  }

  .post-updated {
    color: var(--color-text-secondary);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .post-tag {
    display: inline-block;
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    background-color: var(--color-code-bg);
    border: 1px solid var(--color-border);
    padding: 0.1em 0.6em;
    border-radius: 9999px;
    text-decoration: none;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .post-tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  /* Prose — academic paper body styling */
  .prose {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .prose :global(p) {
    margin-bottom: 1.5em;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    font-family: var(--font-sans);
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
    margin-top: 2em;
    margin-bottom: 0.75em;
    letter-spacing: -0.01em;
    scroll-margin-top: 5rem;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.3em;
  }

  .prose :global(h3) {
    font-size: 1.2rem;
  }

  .prose :global(h4) {
    font-size: 1rem;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    opacity: 0.8;
  }

  /* Blockquote */
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    background-color: var(--color-blockquote-bg);
    margin: 1.5em 0;
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: 0 4px 4px 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .prose :global(blockquote p) {
    margin-bottom: 0;
  }

  /* Code — Shiki dual theme support */
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background-color: var(--color-code-bg);
    padding: 0.15em 0.35em;
    border-radius: 3px;
    border: 1px solid var(--color-border);
    font-style: normal;
  }

  .prose :global(pre) {
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: var(--spacing-lg);
    overflow-x: auto;
    line-height: 1.6;
    margin: 1.5em 0;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
  }

  /* Lists */
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.75em;
    margin-bottom: 1.5em;
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
  }

  .prose :global(li > ul),
  .prose :global(li > ol) {
    margin-top: 0.4em;
    margin-bottom: 0;
  }

  /* Tables */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 0.925rem;
    font-family: var(--font-sans);
  }

  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.6em 0.9em;
    text-align: left;
  }

  .prose :global(th) {
    background-color: var(--color-code-bg);
    font-weight: 600;
    color: var(--color-text);
  }

  .prose :global(tr:nth-child(even) td) {
    background-color: var(--color-blockquote-bg);
  }

  /* Images */
  .prose :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.5em auto;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .prose :global(figure) {
    margin: 1.5em 0;
    text-align: center;
  }

  .prose :global(figcaption) {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: var(--spacing-sm);
    font-style: italic;
    font-family: var(--font-sans);
  }

  /* Horizontal rule */
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--spacing-2xl) 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .toc-trigger {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 1.6rem;
    }

    .prose {
      font-size: 1rem;
    }
  }
</style>

<script>
  const toc = document.querySelector('.toc-sidebar') as HTMLElement | null;
  const trigger = document.querySelector('.toc-trigger') as HTMLElement | null;
  if (toc && trigger) {
    let timer: ReturnType<typeof setTimeout>;
    let hovering = false;

    trigger.addEventListener('mouseenter', () => { hovering = true; });
    trigger.addEventListener('mouseleave', () => { hovering = false; });

    function show() {
      toc!.style.opacity = '1';
      toc!.style.pointerEvents = 'auto';
      clearTimeout(timer);
      timer = setTimeout(() => {
        if (!hovering) {
          toc!.style.removeProperty('opacity');
          toc!.style.removeProperty('pointer-events');
        }
      }, 1500);
    }

    window.addEventListener('scroll', show, { passive: true });
  }
</script>
