---
import '../styles/typography/tokens.css';
import '../styles/typography/page.css';
import '../styles/typography/list.css';
import '../styles/typography/prose.css';
import BaseLayout from './BaseLayout.astro';
import MermaidInit from '../components/MermaidInit.astro';
import CodeCopyButton from '../components/CodeCopyButton.astro';
import Comments from '../components/Comments.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { getCollection } from 'astro:content';
import { entryToPost } from '../modules/post/model';
import { extractSeries } from '../modules/taxonomy/model';
import { translations } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
  lang?: 'ko' | 'en';
  heroImage?: string;
  currentSlug?: string;
  series?: { id: string; order: number };
}

const {
  title,
  description,
  date,
  updatedDate,
  tags = [],
  lang = 'ko',
  heroImage,
  currentSlug = '',
  series,
} = Astro.props;

// 시리즈 정보 가져오기
let seriesPosts: ReturnType<typeof extractSeries>[number]['posts'] = [];
let seriesSlug = '';
if (series) {
  const allPosts = await getCollection('posts');
  const allSeries = extractSeries(allPosts.map(entryToPost));
  const currentSeries = allSeries.find((item) => item.id === series.id);
  seriesPosts = currentSeries?.posts ?? [];
  seriesSlug = currentSeries?.slug ?? '';
}

function formatDate(d: Date, locale: string): string {
  return d.toLocaleDateString(locale, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const locale = lang === 'ko' ? 'ko-KR' : 'en-US';
const formattedDate = formatDate(date, locale);
const formattedUpdatedDate = updatedDate ? formatDate(updatedDate, locale) : null;
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  seoType="article"
  publishedDate={date}
  tags={tags}
>
  <div class="post-with-toc">
    <aside class="toc-sidebar">
      <slot name="toc" />
    </aside>

    <article class="post">
      {heroImage && (
        <figure class="post-hero">
          <img src={heroImage} alt={title} loading="lazy" decoding="async" />
        </figure>
      )}

      <header class="post-header">
        <h1 class="post-title">{title}</h1>

        <div class="post-meta">
          <time class="post-date" datetime={date.toISOString()}>
            {formattedDate}
          </time>
          {formattedUpdatedDate && (
            <span class="post-updated">
              (<span
                data-i18n="post.updated"
                data-i18n-ko={translations.ko['post.updated']}
                data-i18n-en={translations.en['post.updated']}
              >{translations.ko['post.updated']}</span>: <time datetime={updatedDate!.toISOString()}>{formattedUpdatedDate}</time>)
            </span>
          )}
        </div>

        {tags.length > 0 && (
          <div class="post-tags" aria-label="Tags">
            {tags.map((tag) => (
              <a href={`/tags/${tag}`} class="post-tag">#{tag}</a>
            ))}
          </div>
        )}

        {series && seriesPosts.length > 1 && (
          <details class="series-box">
            <summary class="series-summary">
              <div class="series-summary-copy">
                <span class="series-kicker"
                  data-i18n="series.kicker"
                  data-i18n-ko={translations.ko['series.kicker']}
                  data-i18n-en={translations.en['series.kicker']}
                >{translations.ko['series.kicker']}</span>
                <p class="series-title">{series.id}</p>
                <p class="series-progress">{series.order}/{seriesPosts.length} <span
                  data-i18n="series.part"
                  data-i18n-ko={translations.ko['series.part']}
                  data-i18n-en={translations.en['series.part']}
                >{translations.ko['series.part']}</span></p>
              </div>
              <div class="series-summary-meta">
                <div class="series-mini-rail" aria-hidden="true">
                  {seriesPosts.map((post) => (
                    <span class={`series-mini-cell${post.slug === currentSlug ? ' current' : ''}`}></span>
                  ))}
                </div>
                <span class="series-toggle-copy"
                  data-i18n="series.fold"
                  data-i18n-ko={translations.ko['series.fold']}
                  data-i18n-en={translations.en['series.fold']}
                >{translations.ko['series.fold']}</span>
              </div>
            </summary>

            <div class="series-panel">
              <div class="series-panel-header">
                <p class="series-panel-text"
                  data-i18n="series.panelText"
                  data-i18n-ko={translations.ko['series.panelText']}
                  data-i18n-en={translations.en['series.panelText']}
                >{translations.ko['series.panelText']}</p>
                {seriesSlug && <a href={`/series#${seriesSlug}`} class="series-archive-link"
                  data-i18n="series.archiveLink"
                  data-i18n-ko={translations.ko['series.archiveLink']}
                  data-i18n-en={translations.en['series.archiveLink']}
                >{translations.ko['series.archiveLink']}</a>}
              </div>

              <ol class="series-list">
                {seriesPosts.map((post) => (
                  <li class={post.slug === currentSlug ? "current" : ""}>
                    <span class="series-item-order">{String(post.order).padStart(2, '0')}</span>
                    <div class="series-item-body">
                      <a href={`/posts/${post.slug}`}>
                        {post.title}
                      </a>
                      <p>{post.description}</p>
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          </details>
        )}
      </header>

      <div class="post-body prose">
        <slot />
      </div>
    </article>

    <RelatedPosts currentSlug={currentSlug} tags={tags} />
    <Comments />

    <MermaidInit />
    <CodeCopyButton />
  </div>
</BaseLayout>

<script>
  import { initFootnotePreview } from '../components/footnote-preview';
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFootnotePreview);
  } else {
    initFootnotePreview();
  }
</script>

<style>
  /* Layout: post + sliding TOC */
  .post-with-toc {
    position: relative;
  }

  /* Desktop: fixed sidebar on right, revealed on hover/scroll */
  .toc-sidebar {
    position: fixed;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    width: 220px;
    max-height: 55vh;
    z-index: 100;
    padding: 0.75rem;
    opacity: 0;
    transition: opacity 0.4s ease;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: none;
  }

  .toc-sidebar::-webkit-scrollbar {
    display: none;
  }

  .toc-sidebar:hover,
  .toc-sidebar.visible {
    opacity: 1;
  }

  /* Reset inner .toc scroll — sidebar is the sole scroll container */
  .toc-sidebar :global(.toc) {
    position: static;
    max-height: none;
    overflow: visible;
  }

  /* Post */
  .post {
    max-width: 100%;
  }

  .post-hero {
    margin-bottom: var(--spacing-2xl);
    border-radius: 6px;
    overflow: hidden;
  }

  .post-hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-header {
    /* margin-bottom: var(--spacing-lg); */
    margin-bottom: var(--spacing--2xl);
  }

  .post-title {
    margin-bottom: var(--spacing-md);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
  }

  .post-date {
    font-style: normal;
  }

  .post-updated {
    color: var(--color-text-secondary);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
  }

  .series-box {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background-color: var(--color-surface);
    margin-bottom: var(--spacing-xl);
    overflow: hidden;
  }

  .series-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    padding: var(--spacing-lg);
    cursor: pointer;
    list-style: none;
  }

  .series-summary::-webkit-details-marker {
    display: none;
  }

  .series-summary-copy {
    min-width: 0;
  }

  .series-kicker,
  .series-progress,
  .series-toggle-copy,
  .series-item-order,
  .series-list li p {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }

  .series-kicker {
    display: inline-block;
    margin-bottom: 0.2rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .series-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .series-progress {
    margin-top: 0.18rem;
  }

  .series-summary-meta {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    flex-shrink: 0;
  }

  .series-mini-rail {
    display: flex;
    gap: 0.35rem;
    padding-top: 0.1rem;
  }

  .series-mini-cell {
    width: 12px;
    height: 12px;
    border-radius: 2px;
    background-color: var(--color-accent-soft);
    border: 1px solid var(--color-border);
  }

  .series-mini-cell.current {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .series-toggle-copy {
    min-width: 5.5rem;
    text-align: right;
  }

  .series-box[open] .series-toggle-copy {
    color: var(--color-accent);
  }

  .series-panel {
    border-top: 1px solid var(--color-border);
    padding: var(--spacing-lg);
  }

  .series-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .series-panel-text {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .series-archive-link {
    font-size: 0.82rem;
    white-space: nowrap;
    font-family: var(--font-mono);
  }

  .series-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .series-list li {
    display: flex;
    gap: var(--spacing-md);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-border);
  }

  .series-list li:first-child {
    padding-top: 0;
    border-top: none;
  }

  .series-item-order {
    width: 2rem;
    flex-shrink: 0;
    font-family: var(--font-mono);
    padding-top: 0.15rem;
  }

  .series-item-body {
    min-width: 0;
  }

  .series-list li a {
    color: var(--color-text-secondary);
    font-weight: 500;
    text-decoration: none;
  }

  .series-list li a:hover {
    text-decoration: none;
    color: var(--color-text);
  }

  .series-list li.current .series-item-body a {
    color: var(--color-accent);
    font-weight: 700;
    pointer-events: none;
  }

  .series-list li.current .series-item-order {
    color: var(--color-accent);
  }

  .series-list li p {
    margin-top: 0.2rem;
  }

  .post-tag {
    display: inline-block;
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    background-color: var(--color-code-bg);
    border: 1px solid var(--color-border);
    padding: 0.1em 0.6em;
    border-radius: 9999px;
    text-decoration: none;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .post-tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .series-summary,
    .series-panel-header,
    .series-list li {
      flex-direction: column;
    }

    .series-summary-meta {
      width: 100%;
      justify-content: space-between;
      align-items: center;
    }

    .series-toggle-copy {
      min-width: 0;
      text-align: left;
    }

    .series-item-order {
      width: auto;
      padding-top: 0;
    }
  }

  /* Responsive: inline collapsible TOC on smaller screens */
  @media (max-width: 1024px) {
    .toc-sidebar {
      position: static;
      transform: none;
      width: 100%;
      max-height: none;
      opacity: 1;
      pointer-events: auto;
      padding: 0;
      margin-bottom: var(--spacing-xl);
      border: 1px solid var(--color-border);
      border-radius: 6px;
      overflow: visible;
    }
  }

</style>

<script>
  const toc = document.querySelector('.toc-sidebar') as HTMLElement | null;
  if (toc) {
    const isDesktop = () => window.getComputedStyle(toc).position === 'fixed';
    let hideTimer: ReturnType<typeof setTimeout>;
    let hovering = false;

    toc.addEventListener('mouseenter', () => {
      hovering = true;
      clearTimeout(hideTimer);
      toc!.classList.add('visible');
    });

    toc.addEventListener('mouseleave', () => {
      hovering = false;
      scheduleHide();
    });

    function scheduleHide() {
      clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        if (!hovering) toc!.classList.remove('visible');
      }, 1500);
    }

    window.addEventListener('scroll', () => {
      if (!isDesktop()) return;
      toc!.classList.add('visible');
      if (!hovering) scheduleHide();
    }, { passive: true });
  }
</script>
