---
// VimSearch.astro — Fixed bottom search bar for in-page "/" vim search
// Initialization is handled by BaseLayout.astro's unified script
---

<div id="vim-search-bar" hidden role="search" aria-label="In-page search">
  <span class="vim-search-prompt" aria-hidden="true">/</span>
  <input
    class="vim-search-input"
    type="text"
    autocomplete="off"
    autocorrect="off"
    autocapitalize="off"
    spellcheck="false"
    aria-label="Search in page"
    placeholder="Search..."
  />
  <span class="vim-search-count" aria-live="polite" aria-atomic="true"></span>
</div>
