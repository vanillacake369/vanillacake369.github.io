---
// VimSearch.astro — Fixed bottom search bar for in-page "/" vim search
---

<div id="vim-search-bar" hidden role="search" aria-label="In-page search">
  <span class="vim-search-prompt" aria-hidden="true">/</span>
  <input
    class="vim-search-input"
    type="text"
    autocomplete="off"
    autocorrect="off"
    autocapitalize="off"
    spellcheck="false"
    aria-label="Search in page"
    placeholder="Search..."
  />
  <span class="vim-search-count" aria-live="polite" aria-atomic="true"></span>
</div>

<script>
  import * as vimSearch from '../vim/vim-search';

  function init(): void {
    const bar = document.getElementById('vim-search-bar') as HTMLElement | null;
    const input = bar?.querySelector<HTMLInputElement>('.vim-search-input') ?? null;
    const count = bar?.querySelector<HTMLElement>('.vim-search-count') ?? null;

    if (!bar || !input || !count) return;

    vimSearch.init({ bar, input, count });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
