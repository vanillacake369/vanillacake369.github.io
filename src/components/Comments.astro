---
// Giscus - GitHub Discussions-based comments
// Configuration for vanillacake369/vanillacake369.github.io
---

<section class="comments-section">
  <hr class="comments-divider" />
  <div class="giscus"></div>
</section>

<script>
  // Track the theme observer so we can disconnect on re-init
  let themeObserver: MutationObserver | null = null;

  function loadGiscus(): void {
    const container = document.querySelector('.giscus');
    if (!container) return;

    // Disconnect previous observer to prevent accumulation on navigation
    if (themeObserver) {
      themeObserver.disconnect();
      themeObserver = null;
    }

    // Clear previous instance to prevent duplicates during navigation
    container.innerHTML = '';

    const theme = document.documentElement.getAttribute('data-theme') === 'dark'
      ? 'transparent_dark'
      : 'light';
    const lang = document.documentElement.lang === 'ko' ? 'ko' : 'en';

    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.setAttribute('data-repo', 'vanillacake369/vanillacake369.github.io');
    script.setAttribute('data-repo-id', 'R_kgDOG5QfiQ');
    script.setAttribute('data-category', 'Q&A');
    script.setAttribute('data-category-id', 'DIC_kwDOG5Qfic4C84oa');
    script.setAttribute('data-mapping', 'pathname');
    script.setAttribute('data-strict', '0');
    script.setAttribute('data-reactions-enabled', '1');
    script.setAttribute('data-emit-metadata', '0');
    script.setAttribute('data-input-position', 'bottom');
    script.setAttribute('data-theme', theme);
    script.setAttribute('data-lang', lang);
    script.setAttribute('crossorigin', 'anonymous');
    script.async = true;

    container.appendChild(script);

    // Sync theme changes in real-time
    themeObserver = new MutationObserver(() => {
      const newTheme = document.documentElement.getAttribute('data-theme') === 'dark'
        ? 'transparent_dark'
        : 'light';

      const iframe = document.querySelector<HTMLIFrameElement>('iframe.giscus-frame');
      if (iframe) {
        iframe.contentWindow?.postMessage(
          {
            giscus: {
              setConfig: {
                theme: newTheme,
              },
            },
          },
          'https://giscus.app'
        );
      }
    });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  }

  // Initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadGiscus);
  } else {
    loadGiscus();
  }

  // Support for Astro View Transitions
  document.addEventListener('astro:after-swap', loadGiscus);
</script>

<style>
  .comments-section {
    margin-top: var(--spacing-2xl);
  }

  .comments-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-bottom: var(--spacing-2xl);
  }
</style>
