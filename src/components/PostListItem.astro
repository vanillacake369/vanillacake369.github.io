---
import { slugifyTag } from '../domain/post';
import type { Post } from '../domain/types';

interface Props {
  post: Post;
}

const { post } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-CA'); // YYYY-MM-DD
}
---

<li class="post-item">
  <div class="post-item-meta">
    <time class="post-item-date" datetime={post.date.toISOString()}>
      {formatDate(post.date)}
    </time>
  </div>
  <a href={`/posts/${post.slug}`} class="post-item-title">
    {post.title}
  </a>
  <p class="post-item-description">{post.description}</p>
  {post.tags.length > 0 && (
    <div class="post-item-tags">
      {post.tags.map((tag) => (
        <a href={`/tags/${slugifyTag(tag)}`} class="post-item-tag">#{tag}</a>
      ))}
    </div>
  )}
</li>

<style>
  .post-item {
    padding: var(--spacing-xl) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    padding-top: 0;
  }

  .post-item-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xs);
  }

  .post-item-date {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }

  .post-item-title {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: var(--spacing-sm);
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .post-item-title:hover {
    color: var(--color-accent);
  }

  .post-item-description {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--spacing-md);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-item-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .post-item-tag {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .post-item-tag:hover {
    color: var(--color-accent);
  }
</style>
