---
import { getCollection } from 'astro:content';
import { entryToPost, slugify, toLocalDateString } from '../domain/post';

interface Props {
  currentSlug: string;
  tags: string[];
}

const { currentSlug, tags } = Astro.props;

const allPosts = await getCollection('posts');
const related = allPosts
  .filter(p => !p.data.draft && slugify(p.id) !== currentSlug)
  .map(p => ({
    post: entryToPost(p),
    sharedTags: p.data.tags.filter(t => tags.includes(t)),
  }))
  .filter(p => p.sharedTags.length > 0)
  .sort((a, b) => b.sharedTags.length - a.sharedTags.length || b.post.date.getTime() - a.post.date.getTime())
  .slice(0, 4);
---

{related.length > 0 && (
  <section class="related-posts">
    <p class="related-label">Related</p>
    <ul class="related-list">
      {related.map(({ post, sharedTags }) => (
        <li class="related-item">
          <a href={`/posts/${post.slug}/`} class="related-link">
            <span class="related-title">{post.title}</span>
            <span class="related-meta">
              <time datetime={post.date.toISOString()}>{toLocalDateString(post.date)}</time>
              <span class="related-shared">{sharedTags.map(t => `#${t}`).join(' ')}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .related-posts {
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-xl);
  }

  .related-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-md);
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .related-item + .related-item {
    border-top: 1px solid color-mix(in srgb, var(--color-border) 50%, transparent);
  }

  .related-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--spacing-md);
    padding: 0.6rem 0;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .related-link:hover {
    text-decoration: none;
  }

  .related-link:hover .related-title {
    color: var(--color-accent);
  }

  .related-title {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .related-meta {
    display: flex;
    gap: var(--spacing-sm);
    align-items: baseline;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    opacity: 0.6;
  }

  .related-shared {
    display: none;
  }

  @media (min-width: 640px) {
    .related-shared {
      display: inline;
    }
  }
</style>
