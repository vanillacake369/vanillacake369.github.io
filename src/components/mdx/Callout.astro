---
interface Props {
  type?: 'info' | 'warning' | 'danger' | 'tip';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const icons: Record<string, string> = {
  info: 'ℹ️',
  warning: '⚠️',
  danger: '🚨',
  tip: '💡',
};

const defaultTitles: Record<string, string> = {
  info: 'Info',
  warning: 'Warning',
  danger: 'Danger',
  tip: 'Tip',
};
---

<aside class={`callout callout-${type}`} role="note">
  <p class="callout-header">
    <span class="callout-icon">{icons[type]}</span>
    <strong>{title ?? defaultTitles[type]}</strong>
  </p>
  <div class="callout-body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    margin: 1.5em 0;
    padding: 0.75rem 1rem;
    border-left: 3px solid var(--callout-accent, var(--color-accent));
    background: var(--callout-bg, var(--color-blockquote-bg));
    border-radius: 0 6px 6px 0;
  }

  .callout-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.4rem;
    font-size: 0.9rem;
  }

  .callout-icon {
    font-size: 1rem;
  }

  .callout-body {
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .callout-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .callout-info {
    --callout-accent: #3b82f6;
    --callout-bg: color-mix(in srgb, #3b82f6 8%, var(--color-bg));
  }

  .callout-warning {
    --callout-accent: #f59e0b;
    --callout-bg: color-mix(in srgb, #f59e0b 8%, var(--color-bg));
  }

  .callout-danger {
    --callout-accent: #ef4444;
    --callout-bg: color-mix(in srgb, #ef4444 8%, var(--color-bg));
  }

  .callout-tip {
    --callout-accent: #10b981;
    --callout-bg: color-mix(in srgb, #10b981 8%, var(--color-bg));
  }
</style>
