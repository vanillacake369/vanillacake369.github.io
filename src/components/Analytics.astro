---
import { SITE_CONFIG } from '../config';

const token = import.meta.env.PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN;
const isProd = import.meta.env.PROD;
---

{isProd && token && (
  <script
    defer
    src={SITE_CONFIG.analytics.cloudflareBeaconUrl}
    data-cf-beacon={`{"token": "${token}"}`}
  />
)}
