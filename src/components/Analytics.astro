---
// Cloudflare Web Analytics beacon
// Replace CLOUDFLARE_ANALYTICS_TOKEN with your actual token from:
// https://dash.cloudflare.com/ → Web Analytics → your site → Manage site → copy the token
const token = '67d018780362450ba560b299a9a30456'; // 여기에 복사한 토큰값을 넣으세요.
const isProd = import.meta.env.PROD;
---

{isProd && (
  <script
    defer
    src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon={`{"token": "${token}"}`}
  />
)}
