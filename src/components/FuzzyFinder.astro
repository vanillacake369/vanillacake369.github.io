---
// FuzzyFinder.astro — Telescope-style modal for navigating posts by title
// Page list is injected at build time via define:vars inline script.
import { getCollection } from 'astro:content';
import { buildSearchPageList } from '../modules/search/model';

const rawEntries = await getCollection('posts');
const pageList = buildSearchPageList(rawEntries);
---

<div id="vim-fuzzy-overlay" hidden role="dialog" aria-modal="true" aria-label="Fuzzy file finder">
  <div id="vim-fuzzy-modal">
    <div class="vim-fuzzy-header">
      <span class="vim-fuzzy-prompt" aria-hidden="true">&gt;</span>
      <input
        class="vim-fuzzy-input"
        type="text"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
        aria-label="Search posts"
        placeholder="Type to search..."
      />
    </div>

    <div class="vim-fuzzy-body">
      <div class="vim-fuzzy-results" role="listbox" aria-label="Search results"></div>
      <div class="vim-fuzzy-preview" aria-live="polite">
        <div class="vim-fuzzy-preview-placeholder">Select a result to preview</div>
      </div>
    </div>

    <div class="vim-fuzzy-footer">
      <span class="vim-fuzzy-status"></span>
      <div class="vim-fuzzy-hints">
        <span><kbd>↑↓</kbd> navigate</span>
        <span><kbd>Enter</kbd> open</span>
        <span><kbd>Esc</kbd> close</span>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ pageList }}>
  // Inject page list into fuzzy-finder module on load
  window.__fuzzyPages = pageList;
</script>
