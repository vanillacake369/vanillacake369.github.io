---
import '../styles/typography/tokens.css';
import '../styles/typography/page.css';
import '../styles/typography/prose.css';
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing content entry: pages/about');
const { Content } = await render(entry);
const { title, description, lang } = entry.data;
---

<BaseLayout title={title} description={description} lang={lang}>
  <section class="page">
    <header class="page-header">
      <h1 class="page-title">{title}</h1>
      <p class="page-desc">{description}</p>
    </header>
    <div class="page-body prose">
      <Content />
    </div>
  </section>
</BaseLayout>

<style>
  .page-body {
    max-width: 100%;
  }
</style>
