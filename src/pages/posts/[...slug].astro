---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import TOC from '../../components/TOC.astro';
import { slugify, createPost } from '../../modules/post/model';
import { extractSeries } from '../../modules/taxonomy/model';

export async function getStaticPaths() {
  const entries = await getCollection('posts');
  const allPosts = entries.map(e => createPost(e));
  const allSeries = extractSeries(allPosts);

  return entries.map((entry) => {
    const post = createPost(entry);
    const seriesInfo = post.series
      ? allSeries.find(s => s.id === post.series!.id)
      : undefined;

    return {
      params: { slug: slugify(entry.id) },
      props: {
        entry,
        seriesPosts: seriesInfo?.posts ?? [],
        seriesSlug: seriesInfo?.slug ?? '',
      },
    };
  });
}

const { entry, seriesPosts, seriesSlug } = Astro.props;
const post = createPost(entry);
const { Content, headings } = await render(entry);
const { title, description, date, updatedDate, tags, lang, heroImage, series } = post;
---

<PostLayout
  title={title}
  description={description}
  date={date}
  updatedDate={updatedDate}
  tags={tags}
  series={series}
  lang={lang}
  heroImage={heroImage}
  currentSlug={slugify(entry.id)}
  seriesPosts={seriesPosts}
  seriesSlug={seriesSlug}
>
  <TOC headings={headings} slot="toc" />
  <Content />
</PostLayout>
