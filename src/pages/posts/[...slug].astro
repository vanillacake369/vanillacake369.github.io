---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import TOC from '../../components/TOC.astro';
import { slugify, parsePostId, parseSeriesFromId } from '../../modules/post/model';

export async function getStaticPaths() {
  const entries = await getCollection('posts');
  return entries.map((entry) => ({
    params: { slug: slugify(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const parsed = parsePostId(entry.id);
const { description, updatedDate, tags, lang, heroImage } = entry.data;
const series = parsed.series;
const title = entry.data.title || parsed.title;
const date = new Date(parsed.year, parsed.month - 1, parsed.day);
---

<PostLayout
  title={title}
  description={description}
  date={date}
  updatedDate={updatedDate}
  tags={tags}
  series={series}
  lang={lang}
  heroImage={heroImage}
  currentSlug={slugify(entry.id)}
>
  <TOC headings={headings} slot="toc" />
  <Content />
</PostLayout>
