---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import TOC from '../../components/TOC.astro';
import { titleFromId } from '../../domain/post';

export async function getStaticPaths() {
  const entries = await getCollection('posts');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const { description, date, updatedDate, tags, category, lang, heroImage } = entry.data;
const title = entry.data.title || titleFromId(entry.id);
---

<PostLayout
  title={title}
  description={description}
  date={date}
  updatedDate={updatedDate}
  tags={tags}
  category={category}
  lang={lang}
  heroImage={heroImage}
  currentSlug={entry.id}
>
  <TOC headings={headings} slot="toc" />
  <Content />
</PostLayout>
