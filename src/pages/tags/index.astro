---
import '../../styles/typography/tokens.css';
import '../../styles/typography/page.css';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { filterPublished, extractTags, entryToPost } from '../../domain/post';

const rawEntries = await getCollection('posts');

const posts = rawEntries.map(entryToPost);

const publishedPosts = filterPublished(posts);
const tags = extractTags(publishedPosts);
---

<BaseLayout title="Tags" description="Browse posts by tag.">
  <section class="tags-section">
    <header class="page-header">
      <h1 class="page-title">Tags</h1>
      <p class="page-desc">Browse posts by tag.</p>
    </header>

    {tags.length === 0 ? (
      <p class="no-tags">No tags yet.</p>
    ) : (
      <ul class="tag-list">
        {tags.map((tag) => (
          <li class="tag-item">
            <a href={`/tags/${tag.slug}`} class="tag-link">
              <span class="tag-name">#{tag.name}</span>
              <span class="tag-count">{tag.count}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .no-tags {
    color: var(--color-text-secondary);
  }

  .tag-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tag-item {
    border-bottom: 1px solid var(--color-border);
  }

  .tag-item:first-child .tag-link {
    padding-top: 0;
  }

  .tag-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-xl) 0;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .tag-link:hover .tag-name {
    color: var(--color-accent);
  }

  .tag-name {
    font-size: var(--font-size-list-title);
    font-weight: 600;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .tag-count {
    font-size: var(--font-size-meta);
    color: var(--color-text-secondary);
    background-color: var(--color-border);
    padding: 0.1em 0.55em;
    border-radius: 999px;
    font-variant-numeric: tabular-nums;
  }
</style>
