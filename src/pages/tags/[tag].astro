---
import '../../styles/typography/tokens.css';
import '../../styles/typography/page.css';
import '../../styles/typography/list.css';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostListItem from '../../components/PostListItem.astro';
import { filterPublished, filterByTag, sortPostsByDate, extractTags, entryToPost } from '../../modules/post/model';

export async function getStaticPaths() {
  const rawEntries = await getCollection('posts');
  const posts = rawEntries.map(entryToPost);
  const publishedPosts = filterPublished(posts);
  const tags = extractTags(publishedPosts);

  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: {
      tagName: tag.name,
      taggedPosts: sortPostsByDate(filterByTag(publishedPosts, tag.name)),
    },
  }));
}

const { tagName, taggedPosts } = Astro.props;
---

<BaseLayout title={`#${tagName}`} description={`Posts tagged with ${tagName}.`}>
  <section class="post-list-section">
    <header class="page-header">
      <a href="/tags" class="page-back-link">&larr; Tags</a>
      <h1 class="page-title">#{tagName}</h1>
      <p class="page-desc">{taggedPosts.length} {taggedPosts.length === 1 ? 'post' : 'posts'}</p>
    </header>

    {taggedPosts.length === 0 ? (
      <p class="no-posts">No posts with this tag.</p>
    ) : (
      <ul class="post-list">
        {taggedPosts.map((post) => (
          <PostListItem post={post} />
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .no-posts {
    color: var(--color-text-secondary);
  }

  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
</style>
