---
import BaseLayout from '../layouts/BaseLayout.astro';

// Replace with your actual analytics dashboard URL
const ANALYTICS_URL = 'https://dash.cloudflare.com/';
---

<BaseLayout title="Analytics" description="Blog analytics dashboard.">
  <section class="analytics-page">
    <h1 class="page-title">Analytics</h1>
    <p class="analytics-desc">
      External analytics dashboard for this blog.
    </p>
    <a href={ANALYTICS_URL} target="_blank" rel="noopener noreferrer" class="analytics-link">
      Open Cloudflare Dashboard →
    </a>
  </section>
</BaseLayout>

<style>
  .analytics-page {
    text-align: center;
    padding: var(--spacing-2xl) 0;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: var(--spacing-lg);
  }

  .analytics-desc {
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-xl);
  }

  .analytics-link {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-accent);
    color: var(--color-bg);
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.15s ease;
  }

  .analytics-link:hover {
    opacity: 0.85;
    text-decoration: none;
  }
</style>
