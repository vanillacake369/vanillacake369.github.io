---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { filterPublished, groupByCalendarDay, sortPostsByDate, entryToPost } from '../domain/post';
import { generateCalendarGrid } from '../domain/calendar';
import { translations } from '../i18n/translations';

const rawEntries = await getCollection('posts');

const posts = rawEntries.map(entryToPost);

const publishedPosts = filterPublished(posts);
const sortedPosts = sortPostsByDate(publishedPosts);
const calendarDays = groupByCalendarDay(publishedPosts);

// Build a map of date → posts for client-side lookup
const dayPostsMap: Record<string, { slug: string; title: string; tags: string[] }[]> = {};
for (const day of calendarDays) {
  dayPostsMap[day.date] = day.posts.map(p => {
    const full = publishedPosts.find(fp => fp.slug === p.slug);
    return { slug: p.slug, title: p.title, tags: full?.tags ?? [] };
  });
}

// Get all years that have posts
const postYears = [...new Set(publishedPosts.map(p => p.date.getFullYear()))].sort((a, b) => b - a);
const currentYear = new Date().getFullYear();
const availableYears = [...new Set([currentYear, ...postYears])].sort((a, b) => b - a);

// Generate grids for each year
const yearGrids: Record<number, ReturnType<typeof generateCalendarGrid>> = {};
for (const year of availableYears) {
  const yearPosts = publishedPosts.filter(p => p.date.getFullYear() === year);
  yearGrids[year] = generateCalendarGrid(yearPosts, 12);
}

const MONTH_NAMES = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
                     'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const DAY_LABELS = ['', 'Mon', '', 'Wed', '', 'Fri', ''];

function getMonthLabels(weeks: ReturnType<typeof generateCalendarGrid>) {
  const labels: { label: string; colIndex: number }[] = [];
  let lastMonth = -1;
  for (let wi = 0; wi < weeks.length; wi++) {
    const firstCell = weeks[wi].cells.find(c => c !== null);
    if (!firstCell) continue;
    const month = new Date(firstCell.date).getMonth();
    if (month !== lastMonth) {
      labels.push({ label: MONTH_NAMES[month], colIndex: wi });
      lastMonth = month;
    }
  }
  return labels;
}
---

<BaseLayout
  title={translations.ko['calendar.title']}
  description="Post contribution calendar."
>
  <section class="calendar-page">
    <h1
      class="page-title"
      data-i18n="calendar.title"
      data-i18n-ko={translations.ko['calendar.title']}
      data-i18n-en={translations.en['calendar.title']}
    >{translations.ko['calendar.title']}</h1>

    <!-- Year navigation -->
    <div class="year-nav">
      <button id="year-prev" class="year-btn" aria-label="Previous year">&larr;</button>
      <span id="year-label" class="year-label">{currentYear}</span>
      <button id="year-next" class="year-btn" aria-label="Next year">&rarr;</button>
    </div>

    <!-- Calendar graphs per year (only active year visible) -->
    <div class="calendar-scroll-container">
      {availableYears.map(year => {
        const weeks = yearGrids[year];
        const monthLabels = getMonthLabels(weeks);
        return (
          <div class="calendar-year" data-year={year} style={year !== currentYear ? 'display:none;' : ''}>
            <div class="calendar-outer">
              <div class="calendar-month-row">
                <div class="day-label-spacer" aria-hidden="true" />
                <div class="month-labels" style={`grid-template-columns: repeat(${weeks.length}, 15px);`}>
                  {weeks.map((_, wi) => {
                    const label = monthLabels.find(m => m.colIndex === wi);
                    return <span class="month-label" style={`grid-column: ${wi + 1};`}>{label ? label.label : ''}</span>;
                  })}
                </div>
              </div>

              <div class="calendar-body">
                <div class="day-labels" aria-hidden="true">
                  {DAY_LABELS.map(label => <span class="day-label">{label}</span>)}
                </div>

                <div class="calendar-grid" role="grid" style={`grid-template-columns: repeat(${weeks.length}, 15px);`}>
                  {weeks.map((week, wi) =>
                    week.cells.map((cell, dow) => {
                      if (cell === null) {
                        return <span class="cal-cell cal-cell--pad" style={`grid-column:${wi+1};grid-row:${dow+1};`} aria-hidden="true" />;
                      }
                      const tip = cell.posts.length > 0
                        ? `${cell.date}: ${cell.posts.map(p => p.title).join(', ')}`
                        : cell.date;
                      return (
                        <button
                          type="button"
                          class={`cal-cell cal-cell--level-${cell.level}${cell.count > 0 ? ' cal-cell--has-posts' : ''}`}
                          style={`grid-column:${wi+1};grid-row:${dow+1};`}
                          title={tip}
                          data-date={cell.date}
                          data-count={cell.count}
                        />
                      );
                    })
                  )}
                </div>
              </div>

              <div class="calendar-legend">
                <span class="legend-label">Less</span>
                {([0,1,2,3,4] as const).map(level => <span class={`cal-cell cal-cell--level-${level} legend-cell`} />)}
                <span class="legend-label">More</span>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Selected date post list -->
    <div id="day-posts" class="day-posts" hidden>
      <h2 id="day-posts-title" class="day-posts-title"></h2>
      <ul id="day-posts-list" class="day-posts-list"></ul>
    </div>

    <!-- All posts list -->
    <section class="post-list-section">
      <h2 class="post-list-title">All Posts</h2>
      {sortedPosts.length === 0 ? (
        <p class="no-posts">No posts yet.</p>
      ) : (
        <ul class="post-list">
          {sortedPosts.map(post => (
            <li class="post-item">
              <time class="post-item-date" datetime={post.date.toISOString()}>
                {post.date.toLocaleDateString('en-CA')}
              </time>
              <a href={`/posts/${post.slug}`} class="post-item-title">{post.title}</a>
              {post.tags.length > 0 && (
                <div class="post-item-tags">
                  {post.tags.map(tag => <a href={`/tags/${tag}`} class="post-item-tag">#{tag}</a>)}
                </div>
              )}
            </li>
          ))}
        </ul>
      )}
    </section>
  </section>
</BaseLayout>

<script define:vars={{ dayPostsMap, availableYears, currentYear }}>
  // Year navigation
  let activeYear = currentYear;
  const yearLabel = document.getElementById('year-label');
  const prevBtn = document.getElementById('year-prev');
  const nextBtn = document.getElementById('year-next');

  function showYear(year) {
    document.querySelectorAll('.calendar-year').forEach(el => {
      el.style.display = el.dataset.year === String(year) ? '' : 'none';
    });
    yearLabel.textContent = String(year);
    activeYear = year;
    // Hide day-posts when switching years
    document.getElementById('day-posts').hidden = true;
  }

  prevBtn?.addEventListener('click', () => {
    const idx = availableYears.indexOf(activeYear);
    if (idx < availableYears.length - 1) showYear(availableYears[idx + 1]);
  });
  nextBtn?.addEventListener('click', () => {
    const idx = availableYears.indexOf(activeYear);
    if (idx > 0) showYear(availableYears[idx - 1]);
  });

  // Cell click → show day's posts
  document.querySelectorAll('.cal-cell--has-posts').forEach(cell => {
    cell.addEventListener('click', () => {
      const date = cell.dataset.date;
      const posts = dayPostsMap[date];
      if (!posts || posts.length === 0) return;

      const container = document.getElementById('day-posts');
      const title = document.getElementById('day-posts-title');
      const list = document.getElementById('day-posts-list');

      title.textContent = date;
      list.innerHTML = '';
      for (const p of posts) {
        const li = document.createElement('li');
        li.className = 'day-post-item';
        li.innerHTML = `<a href="/posts/${p.slug}/" class="day-post-link">${p.title}</a>` +
          (p.tags.length > 0
            ? `<span class="day-post-tags">${p.tags.map(t => '#' + t).join(' ')}</span>`
            : '');
        list.appendChild(li);
      }
      container.hidden = false;
      container.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

      // Highlight active cell
      document.querySelectorAll('.cal-cell--active').forEach(c => c.classList.remove('cal-cell--active'));
      cell.classList.add('cal-cell--active');
    });
  });
</script>

<style>
  .calendar-page { max-width: 100%; }

  .page-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--spacing-md);
  }

  /* Year navigation */
  .year-nav {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }
  .year-btn {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.3rem 0.6rem;
    cursor: pointer;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    transition: color 0.15s, border-color 0.15s;
  }
  .year-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .year-label {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    min-width: 3rem;
    text-align: center;
  }

  /* Calendar scroll container */
  .calendar-scroll-container {
    max-height: 220px;
    overflow-y: auto;
    overflow-x: auto;
    scrollbar-width: thin;
    margin-bottom: var(--spacing-lg);
  }

  .calendar-outer {
    min-width: min-content;
    padding-bottom: var(--spacing-sm);
  }

  /* Month labels */
  .calendar-month-row { display: flex; align-items: flex-end; gap: 6px; margin-bottom: 4px; }
  .day-label-spacer { width: 32px; flex-shrink: 0; }
  .month-labels { display: grid; gap: 3px; }
  .month-label { font-size: 0.7rem; color: var(--color-text-secondary); white-space: nowrap; line-height: 1; }

  /* Calendar body */
  .calendar-body { display: flex; align-items: flex-start; gap: 6px; }
  .day-labels { display: grid; grid-template-rows: repeat(7, 15px); gap: 3px; width: 32px; flex-shrink: 0; }
  .day-label { font-size: 0.7rem; color: var(--color-text-secondary); line-height: 15px; text-align: right; }
  .calendar-grid { display: grid; grid-template-rows: repeat(7, 15px); gap: 3px; }

  /* Cells */
  .cal-cell {
    display: block; width: 12px; height: 12px; border-radius: 2px;
    border: 1px solid transparent; transition: opacity 0.1s ease;
    padding: 0; cursor: default; background: none;
    font-size: 0;
  }
  .cal-cell--pad { pointer-events: none; }
  .cal-cell--level-0 { border-color: var(--color-border); }
  .cal-cell--level-1 { background: color-mix(in srgb, var(--color-accent) 40%, transparent); }
  .cal-cell--level-2 { background: color-mix(in srgb, var(--color-accent) 65%, transparent); }
  .cal-cell--level-3 { background: color-mix(in srgb, var(--color-accent) 85%, transparent); }
  .cal-cell--level-4 { background: var(--color-accent); }

  .cal-cell--has-posts { cursor: pointer; }
  .cal-cell--has-posts:hover { outline: 2px solid var(--color-accent); outline-offset: 1px; opacity: 0.8; }
  .cal-cell--active { outline: 2px solid var(--color-accent); outline-offset: 1px; }

  /* Legend */
  .calendar-legend {
    display: flex; align-items: center; gap: 4px;
    margin-top: var(--spacing-sm); padding-left: calc(32px + 6px);
  }
  .legend-label { font-size: 0.7rem; color: var(--color-text-secondary); }

  /* Day posts panel */
  .day-posts {
    margin-bottom: var(--spacing-xl);
    padding: var(--spacing-md);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-code-bg);
  }
  .day-posts-title {
    font-size: 0.95rem; font-weight: 600; color: var(--color-text);
    margin-bottom: var(--spacing-sm);
  }
  .day-posts-list { list-style: none; padding: 0; }
  :global(.day-post-item) {
    display: flex; align-items: baseline; gap: var(--spacing-sm);
    padding: 0.25rem 0;
  }
  :global(.day-post-link) {
    color: var(--color-accent); text-decoration: none; font-weight: 500;
  }
  :global(.day-post-link:hover) { text-decoration: underline; }
  :global(.day-post-tags) { font-size: 0.75rem; color: var(--color-text-secondary); }

  /* All posts */
  .post-list-section { margin-top: var(--spacing-xl); padding-top: var(--spacing-xl); border-top: 1px solid var(--color-border); }
  .post-list-title { font-size: 1.1rem; font-weight: 600; margin-bottom: var(--spacing-lg); }
  .post-list { list-style: none; padding: 0; }
  .post-item {
    display: grid; grid-template-columns: 7rem 1fr; column-gap: var(--spacing-md);
    row-gap: 0.15rem; padding: var(--spacing-sm) 0; border-bottom: 1px solid var(--color-border);
    align-items: baseline;
  }
  .post-item:last-child { border-bottom: none; }
  .post-item-date { font-size: 0.8rem; color: var(--color-text-secondary); font-variant-numeric: tabular-nums; }
  .post-item-title { font-size: 0.95rem; font-weight: 500; color: var(--color-text); text-decoration: none; transition: color 0.15s; }
  .post-item-title:hover { color: var(--color-accent); }
  .post-item-tags { display: flex; flex-wrap: wrap; gap: var(--spacing-sm); grid-column: 2; }
  .post-item-tag { font-size: 0.75rem; color: var(--color-text-secondary); text-decoration: none; }
  .post-item-tag:hover { color: var(--color-accent); }

  @media (max-width: 640px) {
    .calendar-scroll-container { margin: 0 calc(-1 * var(--spacing-md)); padding: 0 var(--spacing-md); }
    .post-item { grid-template-columns: 1fr; }
    .post-item-tags { grid-column: 1; }
  }
</style>
