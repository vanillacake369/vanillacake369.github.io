---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { filterPublished } from '../domain/post';
import { generateCalendarGrid } from '../domain/calendar';
import type { Post } from '../domain/types';

const rawEntries = await getCollection('posts');

const posts: Post[] = rawEntries.map((entry) => ({
  slug: entry.id,
  title: entry.data.title,
  description: entry.data.description,
  date: entry.data.date,
  updatedDate: entry.data.updatedDate,
  tags: entry.data.tags,
  category: entry.data.category,
  lang: entry.data.lang,
  draft: entry.data.draft,
  heroImage: entry.data.heroImage,
}));

const publishedPosts = filterPublished(posts);
const MONTHS = 12;
const weeks = generateCalendarGrid(publishedPosts, MONTHS);

// Build month labels: for each week, record which months start in that column
// so we can render a label row above.
const MONTH_NAMES = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
                     'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

interface MonthLabel {
  label: string;
  colIndex: number;
}

const monthLabels: MonthLabel[] = [];
let lastMonth = -1;
for (let wi = 0; wi < weeks.length; wi++) {
  // Use the first non-null cell in the week to determine its month
  const firstCell = weeks[wi].cells.find((c) => c !== null);
  if (!firstCell) continue;
  const month = new Date(firstCell.date).getMonth();
  if (month !== lastMonth) {
    monthLabels.push({ label: MONTH_NAMES[month], colIndex: wi });
    lastMonth = month;
  }
}

const DAY_LABELS = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
const SHOW_DAY_ROWS = [1, 3, 5]; // Mon, Wed, Fri (0-indexed: Sun=0)
---

<BaseLayout title="Calendar" description="Post contribution calendar.">
  <section class="calendar-section">
    <h1 class="page-title">Calendar</h1>
    <p class="page-subtitle">
      Posting activity over the last {MONTHS} months.
    </p>

    <div class="calendar-outer">
      <!-- Month label row -->
      <div class="calendar-month-row">
        <div class="day-label-spacer"></div>
        <div
          class="month-labels"
          style={`grid-template-columns: repeat(${weeks.length}, 15px);`}
        >
          {weeks.map((_, wi) => {
            const label = monthLabels.find((m) => m.colIndex === wi);
            return (
              <span class="month-label" style={`grid-column: ${wi + 1};`}>
                {label ? label.label : ''}
              </span>
            );
          })}
        </div>
      </div>

      <!-- Calendar body: day-of-week labels + grid -->
      <div class="calendar-body">
        <!-- Day-of-week labels -->
        <div class="day-labels">
          {DAY_LABELS.map((label, dow) => (
            <span class="day-label">
              {SHOW_DAY_ROWS.includes(dow) ? label : ''}
            </span>
          ))}
        </div>

        <!-- Grid: columns = weeks, rows = days of week -->
        <div
          class="calendar-grid"
          style={`grid-template-columns: repeat(${weeks.length}, 15px);`}
        >
          {weeks.map((week, wi) =>
            week.cells.map((cell, dow) => {
              if (cell === null) {
                return (
                  <span
                    class="cal-cell cal-cell--empty"
                    style={`grid-column: ${wi + 1}; grid-row: ${dow + 1};`}
                  />
                );
              }
              const tooltipText = cell.posts.length > 0
                ? `${cell.date}: ${cell.posts.map((p) => p.title).join(', ')}`
                : cell.date;
              return (
                <a
                  href={`/posts/${cell.posts[0]?.slug ?? ''}`}
                  class={`cal-cell cal-cell--level-${cell.level}`}
                  style={`grid-column: ${wi + 1}; grid-row: ${dow + 1};`}
                  title={tooltipText}
                  aria-label={tooltipText}
                  tabindex={cell.count > 0 ? 0 : -1}
                  data-date={cell.date}
                  data-count={cell.count}
                />
              );
            })
          )}
        </div>
      </div>

      <!-- Legend -->
      <div class="calendar-legend">
        <span class="legend-label">Less</span>
        {[0, 1, 2, 3, 4].map((level) => (
          <span class={`cal-cell cal-cell--level-${level} legend-cell`} />
        ))}
        <span class="legend-label">More</span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-2xl);
  }

  /* ------------------------------------------------------------------ */
  /* Outer wrapper — allows horizontal scroll on narrow viewports       */
  /* ------------------------------------------------------------------ */
  .calendar-outer {
    overflow-x: auto;
    padding-bottom: var(--spacing-sm);
  }

  /* ------------------------------------------------------------------ */
  /* Month label row                                                     */
  /* ------------------------------------------------------------------ */
  .calendar-month-row {
    display: flex;
    align-items: flex-end;
    gap: 6px;
    margin-bottom: 4px;
  }

  .day-label-spacer {
    width: 32px;
    flex-shrink: 0;
  }

  .month-labels {
    display: grid;
    gap: 3px;
  }

  .month-label {
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
    line-height: 1;
  }

  /* ------------------------------------------------------------------ */
  /* Calendar body                                                       */
  /* ------------------------------------------------------------------ */
  .calendar-body {
    display: flex;
    align-items: flex-start;
    gap: 6px;
  }

  .day-labels {
    display: grid;
    grid-template-rows: repeat(7, 15px);
    gap: 3px;
    width: 32px;
    flex-shrink: 0;
  }

  .day-label {
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    line-height: 15px;
    text-align: right;
    white-space: nowrap;
  }

  /* ------------------------------------------------------------------ */
  /* Grid                                                                */
  /* ------------------------------------------------------------------ */
  .calendar-grid {
    display: grid;
    grid-template-rows: repeat(7, 15px);
    gap: 3px;
  }

  /* ------------------------------------------------------------------ */
  /* Cells                                                               */
  /* ------------------------------------------------------------------ */
  .cal-cell {
    display: block;
    width: 12px;
    height: 12px;
    border-radius: 2px;
    border: 1px solid transparent;
    text-decoration: none;
    transition: opacity 0.1s ease;
  }

  .cal-cell--empty {
    /* padding cell outside the date range */
    background: transparent;
    border-color: transparent;
    pointer-events: none;
  }

  .cal-cell--level-0 {
    background: transparent;
    border-color: var(--color-border);
  }

  .cal-cell--level-1 {
    background: color-mix(in srgb, var(--color-accent) 25%, transparent);
    border-color: transparent;
  }

  .cal-cell--level-2 {
    background: color-mix(in srgb, var(--color-accent) 50%, transparent);
    border-color: transparent;
  }

  .cal-cell--level-3 {
    background: color-mix(in srgb, var(--color-accent) 75%, transparent);
    border-color: transparent;
  }

  .cal-cell--level-4 {
    background: var(--color-accent);
    border-color: transparent;
  }

  a.cal-cell:hover {
    opacity: 0.75;
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }

  /* ------------------------------------------------------------------ */
  /* Legend                                                              */
  /* ------------------------------------------------------------------ */
  .calendar-legend {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: var(--spacing-md);
  }

  .legend-label {
    font-size: 0.7rem;
    color: var(--color-text-secondary);
  }

  .legend-cell {
    flex-shrink: 0;
  }
</style>
