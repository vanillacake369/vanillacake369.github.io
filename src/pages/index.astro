---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostListItem from '../components/PostListItem.astro';
import { sortPostsByDate, filterPublished, entryToPost } from '../domain/post';
import { translations } from '../i18n/translations';
import { SITE_CONFIG } from '../config';

const rawEntries = await getCollection('posts');
const posts = rawEntries.map(entryToPost);
const publishedPosts = sortPostsByDate(filterPublished(posts));
---

<BaseLayout title={SITE_CONFIG.title} description={SITE_CONFIG.description}>
  <section class="post-list-section">
    <h1
      class="page-title"
      data-i18n="posts.title"
      data-i18n-ko={translations.ko['posts.title']}
      data-i18n-en={translations.en['posts.title']}
    >{translations.ko['posts.title']}</h1>
    {publishedPosts.length === 0 ? (
      <p
        class="no-posts"
        data-i18n="posts.noPosts"
        data-i18n-ko={translations.ko['posts.noPosts']}
        data-i18n-en={translations.en['posts.noPosts']}
      >{translations.ko['posts.noPosts']}</p>
    ) : (
      <ul class="post-list">
        {publishedPosts.map((post) => (
          <PostListItem post={post} />
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--spacing-xl);
    letter-spacing: -0.02em;
  }

  .no-posts {
    color: var(--color-text-secondary);
  }

  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
</style>
