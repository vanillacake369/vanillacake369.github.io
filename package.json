{
  "name": "tonys-blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "optimize-images": "node scripts/optimize-images.mjs",
    "lint:md": "node scripts/lint-markdown.mjs",
    "lint:md:fix": "node scripts/lint-markdown.mjs --fix",
    "prefix-dates": "node scripts/prefix-dates.mjs",
    "prefix-dates:apply": "node scripts/prefix-dates.mjs --apply",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.1",
    "astro-robots-txt": "^1.0.0",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-footnotes": "^2.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@testing-library/dom": "^10.4.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "pagefind": "^1.5.2",
    "vitest": "^4.1.6"
  }
}
